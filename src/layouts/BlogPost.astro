---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Page from './Page.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt } = Astro.props;
---

<Page
	title={title}
	description={description}
	image={heroImage}
	pubDate={pubDate}
	updatedDate={updatedDate}
	sheetLabel="SOVEREIGN BRAIN · ARTICLE · SHEET A-07"
>
	<article>
		<div class="cut"><span class="tag"><b>A·07</b> · ARTICLE</span></div>

		<header class="post-head">
			<div class="date mono">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<span class="updated"> · updated <FormattedDate date={updatedDate} /></span>
					)
				}
			</div>
			<h1>{title}</h1>
		</header>

		{
			heroImage && (
				<div class="figframe">
					<Image
						src={heroImage}
						alt={heroImageAlt ?? title}
						widths={[480, 760, 1100]}
						sizes="(max-width: 760px) 100vw, 720px"
						loading="eager"
					/>
				</div>
			)
		}

		<div class="prose">
			<slot />
		</div>

		<p class="backlink"><a href="/blog">← All articles</a></p>
	</article>
</Page>

<style>
	article {
		max-width: 720px;
		margin: 0 auto;
	}
	.post-head {
		text-align: center;
		margin-bottom: 26px;
	}
	.date {
		font-size: 12px;
		letter-spacing: 1px;
		color: var(--ink-soft);
	}
	.post-head h1 {
		margin-top: 10px;
	}
	.figframe {
		border: 1.5px solid var(--ink);
		background: var(--panel);
		overflow: hidden;
		aspect-ratio: 16 / 10;
		margin-bottom: 34px;
	}
	.figframe :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* article body */
	.prose {
		font-size: 18px;
		line-height: 1.7;
	}
	.prose :global(h2) {
		font-family: var(--serif);
		font-weight: 600;
		font-size: clamp(24px, 3vw, 30px);
		margin: 2em 0 0.4em;
	}
	.prose :global(h3) {
		font-weight: 600;
		font-size: 22px;
		margin: 1.6em 0 0.4em;
	}
	.prose :global(p),
	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.1em;
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--accent);
		margin: 1.5em 0;
		padding: 0.2em 0 0.2em 1em;
		color: var(--ink-soft);
		font-style: italic;
	}
	.prose :global(img) {
		border: 1.5px solid var(--ink);
	}
	.backlink {
		margin-top: 3em;
		font-family: var(--mono);
		font-size: 13px;
	}
	.backlink a {
		color: var(--accent);
		text-decoration: none;
	}
</style>
