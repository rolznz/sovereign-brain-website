---
import { SITE_TITLE, TEMPLATE_REPO } from '../consts';
---

<header class="topbar">
	<a class="logo" href="/">
		<span class="mark"><span></span></span>
		<b>{SITE_TITLE}</b>
	</a>
	<nav>
		<span class="links">
			<a href="/">Home</a>
			<a href="/#how">How it works</a>
			<a href="/#faq">FAQ</a>
			<a href="/blog">Blog</a>
		</span>
		<a href={TEMPLATE_REPO} class="gh" title="Sovereign Brain on GitHub" target="_blank" rel="noopener">
			<span class="sr-only">Sovereign Brain template on GitHub</span>
			GH
		</a>
	</nav>
</header>

<style>
	.topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		padding: 6px 0 16px;
		border-bottom: 1px solid var(--line);
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 11px;
		flex: 0 0 auto;
		text-decoration: none;
		color: var(--ink);
	}
	.logo .mark {
		width: 30px;
		height: 30px;
		border: 1.5px solid var(--ink);
		border-radius: 50%;
		display: grid;
		place-items: center;
	}
	.logo .mark span {
		width: 9px;
		height: 9px;
		border: 1.5px solid var(--ink);
		border-radius: 50%;
	}
	.logo b {
		font-family: var(--serif);
		font-weight: 600;
		font-size: 19px;
		letter-spacing: 0.2px;
		white-space: nowrap;
	}
	nav {
		display: flex;
		gap: 26px;
		align-items: center;
		font-family: var(--mono);
		font-size: 13px;
	}
	.links {
		display: flex;
		gap: 26px;
		align-items: center;
	}
	nav a {
		color: var(--ink);
		text-decoration: none;
		padding-bottom: 3px;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav .gh {
		width: 26px;
		height: 26px;
		border: 1.5px solid var(--ink);
		border-radius: 50%;
		display: grid;
		place-items: center;
		font-size: 11px;
		padding-bottom: 0;
	}
	@media (max-width: 680px) {
		.links {
			display: none;
		}
	}
</style>
