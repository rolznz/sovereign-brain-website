---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	TEMPLATE_USE_URL,
	TEMPLATE_ZIP_URL,
} from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Own your second brain.</h1>
				<p class="lead">
					A sovereign brain is a self-owned knowledge system built from plain
					Markdown files — no lock-in, no subscription, no cloud you don't
					control. Download the free, agent-ready template and start today.
				</p>
				<div class="cta">
					<a class="btn" href={TEMPLATE_USE_URL}>Get the template</a>
					<a class="btn secondary" href={TEMPLATE_ZIP_URL}>Download ZIP</a>
				</div>
			</section>

			<section id="how-it-works">
				<h2>How it works</h2>
				<div class="grid">
					<div class="card">
						<h3>1. Get the files</h3>
						<p>
							Clone the template or click “Use this template.” You get a clean
							folder of Markdown — a home note, conventions, and agent
							instructions.
						</p>
					</div>
					<div class="card">
						<h3>2. Open it anywhere</h3>
						<p>
							Works with Obsidian, VS Code, or any plain-text editor. It's just
							files on your disk — yours forever, fully portable.
						</p>
					</div>
					<div class="card">
						<h3>3. Grow it your way</h3>
						<p>
							Capture, link, and write. Sync with git, iCloud, or nothing at
							all. Point your AI agent at it via <code>AGENTS.md</code>.
						</p>
					</div>
				</div>
			</section>

			<section id="why">
				<h2>Why sovereign?</h2>
				<ul class="why">
					<li><strong>Plain text outlives apps.</strong> Markdown still opens in 20 years.</li>
					<li><strong>No lock-in.</strong> No proprietary database, no export hostage situation.</li>
					<li><strong>Privacy by default.</strong> The files live where you put them.</li>
					<li><strong>Agent-ready.</strong> Ships with an <code>AGENTS.md</code> so AI tools work with your brain.</li>
				</ul>
				<a class="btn" href={TEMPLATE_USE_URL}>Start your sovereign brain</a>
			</section>

			{
				posts.length > 0 && (
					<section id="latest">
						<h2>From the blog</h2>
						<ul class="posts">
							{posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</li>
							))}
						</ul>
						<a href="/blog">All articles →</a>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2rem 0 1rem;
	}
	.lead {
		font-size: 1.2rem;
		max-width: 38rem;
	}
	.cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}
	.btn {
		display: inline-block;
		background: var(--accent);
		color: #fff;
		padding: 0.7rem 1.3rem;
		border-radius: 8px;
		font-weight: 700;
		text-decoration: none;
	}
	.btn:hover {
		background: var(--accent-dark);
		color: #fff;
	}
	.btn.secondary {
		background: transparent;
		color: var(--accent);
		border: 1px solid rgb(var(--gray-light));
	}
	.btn.secondary:hover {
		background: rgb(var(--gray-light));
		color: var(--accent-dark);
	}
	section {
		margin-top: 3rem;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 1rem;
	}
	.card {
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 1.25rem;
	}
	.card h3 {
		margin-top: 0;
	}
	.why {
		padding-left: 1.1rem;
	}
	.why li {
		margin-bottom: 0.5rem;
	}
	.posts {
		list-style: none;
		padding: 0;
	}
	.posts li {
		margin-bottom: 0.8rem;
	}
	.posts .date {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
</style>
