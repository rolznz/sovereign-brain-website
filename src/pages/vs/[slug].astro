---
import Page from '../../layouts/Page.astro';
import { SITE_TITLE, TEMPLATE_USE_URL } from '../../consts';
import { comparisons } from '../../data/comparisons';

export function getStaticPaths() {
	return comparisons.map((c, i) => ({ params: { slug: c.slug }, props: { ...c, index: i } }));
}

const c = Astro.props;
const sheetNo = String(20 + (c.index ?? 0)).padStart(2, '0');

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: c.heading,
	description: c.description,
	mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
	publisher: { '@type': 'Organization', name: SITE_TITLE },
};
---

<Page
	title={c.title}
	description={c.description}
	sheetLabel={`SOVEREIGN BRAIN · COMPARE · SHEET A-${sheetNo}`}
>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify(jsonLd)}
		is:inline
	/>

	<article class="doc">
		<div class="cut"><span class="tag"><b>A·{sheetNo}</b> · COMPARISON</span></div>
		<h1>{c.heading}</h1>
		<p class="lead muted">{c.intro}</p>

		<div class="cut"><span class="tag"><b>·</b> FEATURE COMPARISON</span></div>
		<div class="panel">
			<div class="ttl"><span>SOVEREIGN BRAIN vs {c.name.toUpperCase()}</span><span>OPEN vs CLOSED</span></div>
			<div class="table-wrap">
				<table>
					<thead>
						<tr>
							<th>Feature</th>
							<th>Sovereign Brain</th>
							<th>{c.name}</th>
						</tr>
					</thead>
					<tbody>
						{
							c.rows.map((row) => (
								<tr>
									<th scope="row">{row.feature}</th>
									<td class="ours">{row.sovereign}</td>
									<td>{row.competitor}</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
		</div>

		<div class="cut"><span class="tag"><b>·</b> WHERE {c.name.toUpperCase()} WINS</span></div>
		<div class="sec-head"><h2>Where {c.name} wins</h2></div>
		<p class="body">{c.competitorWins}</p>

		<div class="cut"><span class="tag"><b>·</b> THE VERDICT</span></div>
		<div class="sec-head"><h2>The verdict</h2></div>
		<p class="body">{c.verdict}</p>

		<div class="cta-row">
			<a class="btn primary" href={TEMPLATE_USE_URL}>Get the free template <span class="arr">→</span></a>
		</div>
	</article>
</Page>

<style>
	.doc {
		max-width: 760px;
		margin: 0 auto;
	}
	.lead {
		margin-top: 14px;
	}
	.body {
		font-size: 18px;
		line-height: 1.7;
		max-width: 64ch;
	}
	.panel {
		border: 1.5px solid var(--ink);
		background: var(--panel);
		margin-top: 4px;
	}
	.panel .ttl {
		font-family: var(--mono);
		font-size: 11px;
		letter-spacing: 1.5px;
		color: var(--ink-soft);
		padding: 11px 18px;
		border-bottom: 1px dashed var(--line);
		display: flex;
		justify-content: space-between;
		gap: 12px;
	}
	.table-wrap {
		overflow-x: auto;
	}
	table {
		border-collapse: collapse;
		width: 100%;
		font-size: 15px;
	}
	th,
	td {
		text-align: left;
		padding: 12px 16px;
		border-bottom: 1px dashed var(--line-soft);
		vertical-align: top;
	}
	thead th {
		font-family: var(--mono);
		font-size: 11px;
		letter-spacing: 1px;
		text-transform: uppercase;
		color: var(--ink-soft);
		border-bottom: 1px solid var(--line);
	}
	tbody th {
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 400;
		color: var(--accent);
		letter-spacing: 0.5px;
		white-space: nowrap;
	}
	tbody tr:last-child th,
	tbody tr:last-child td {
		border-bottom: 0;
	}
	td.ours {
		font-weight: 600;
	}
</style>
