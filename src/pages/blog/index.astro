---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Page from '../../layouts/Page.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = 'Blog — Local & Private AI Second Brain | Sovereign Brain';
const description =
	'Guides and notes on building a local, private AI second brain: local LLMs, agents, and plain-Markdown knowledge systems you fully own.';
---

<Page title={title} description={description}>
	<h1>Blog</h1>
	<p class="lead">Building a local, private AI second brain — setup guides, ideas, and lessons learned.</p>

	<ul class="posts">
		{
			posts.map((post) => (
				<li>
					<a class="post-title" href={`/blog/${post.id}/`}>{post.data.title}</a>
					<p class="date">
						<FormattedDate date={post.data.pubDate} />
					</p>
					{post.data.description && <p class="desc">{post.data.description}</p>}
				</li>
			))
		}
	</ul>
</Page>

<style>
	.lead {
		font-size: 1.15rem;
		color: rgb(var(--gray-dark));
	}
	.posts {
		list-style: none;
		padding: 0;
		margin-top: 2rem;
	}
	.posts li {
		padding-bottom: 1.5rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-title {
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
	}
	.post-title:hover {
		text-decoration: underline;
	}
	.date {
		margin: 0.3rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
	.desc {
		margin: 0.5rem 0 0;
	}
</style>
